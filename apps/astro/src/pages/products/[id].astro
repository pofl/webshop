---
import { formatPrice } from "@webshop/shared";
import Layout from "../../layouts/Layout.astro";
import { countCartItems, getProductById } from "@webshop/database";
import { db } from "../../lib/db.js";

const id = Number(Astro.params.id);
const product = Number.isInteger(id) ? getProductById(db, id) : null;
const cartCount = countCartItems(db);
---

<Layout title={product?.name ?? "Product not found"} cartCount={cartCount}>
  {
    product ? (
      <>
        <a href="/" class="back-link">&larr; Back to search</a>
        <section class="card">
          <h1>{product.name}</h1>
          <p class="muted">{product.description}</p>
          <p class="product-price-large">{formatPrice(product.price_cents)}</p>
          <form method="post" action="/cart/add">
            <input type="hidden" name="product_id" value={product.id} />
            <button type="submit">Add to Cart</button>
          </form>
        </section>
      </>
    ) : (
      <section class="card">
        <h1>Product not found</h1>
        <a href="/">Back to search</a>
      </section>
    )
  }
</Layout>
