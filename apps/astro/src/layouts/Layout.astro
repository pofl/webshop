---
interface Props {
  title: string;
  cartCount?: number;
}

const { title, cartCount = 0 } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js"></script>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="site-title">Web Shop</a>
      <a href="/cart" class="cart-button">
        🛒 Cart
        {cartCount > 0 && <span class="cart-badge">{cartCount}</span>}
      </a>
    </header>
    <main class="container">
      <slot />
    </main>
  </body>
</html>
